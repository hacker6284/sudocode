                },
                {
                  "$ref": "#/definitions/BoundaryTy"
                }
              ],
              "maxItems": 2,
              "minItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "Tuple"
