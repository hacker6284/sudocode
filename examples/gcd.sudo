// Euclid's algorithm. Note: sudo `mod` is floor modulo (sign of divisor),
// so intermediate values stay well-behaved for negative inputs; we take
// abs at the end to return the canonical non-negative gcd.

export func gcd(a: int, b: int) -> int
    while b != 0
        a, b = b, a mod b
    return abs(a)

test "basic"
    assert gcd(12, 18) == 6
    assert gcd(7, 13) == 1

test "zero and negatives"
    assert gcd(0, 5) == 5
    assert gcd(-4, 6) == 2
    assert gcd(0, 0) == 0
